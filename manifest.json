{
  "manifest_version" : 3,
  "name" : "Prince Mfinanga Extension",
  "version" : "0.2",
  "content_scripts" : [
    {
      "matches" : [
        "<all_urls>"
      ],
      "js": ["sketch/p5/p5/p5.min.js", "content.js"]
    }
  ],
  "background" : {
    "service_worker" : "background.js"
  },
  "action" : {
    "default_icon" : "some_icon.png",
    "default_popup" : "sketch/index.html",
    "default_title" : "Lookup a definition!"
  }
}